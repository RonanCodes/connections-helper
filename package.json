{
  "name": "connections-helper",
  "version": "2.0.0",
  "description": "NYT Connections puzzle helper. Shows word definitions to help solve the daily puzzle.",
  "keywords": [
    "nyt",
    "connections",
    "puzzle",
    "word-game",
    "definitions",
    "tanstack-start",
    "cloudflare-workers"
  ],
  "homepage": "https://connectionshelper.app",
  "bugs": {
    "url": "https://github.com/RonanCodes/connections-helper/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Ronan Connolly",
    "url": "https://ronanconnolly.dev"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RonanCodes/connections-helper.git"
  },
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "pnpm run build && wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:integration": "start-server-and-test dev http://localhost:3000 'vitest run --config vitest.integration.config.ts'",
    "test:api": "start-server-and-test dev http://localhost:3000 'cd bruno && bru run . -r --env local'",
    "test:api:prod": "cd bruno && bru run . -r --env production",
    "lint": "eslint",
    "format": "prettier --check .",
    "check": "prettier --write . && eslint --fix",
    "audit:deps": "pnpm audit --audit-level=high",
    "quality-checks": "pnpm run format && pnpm run lint && pnpm run build && pnpm run test && pnpm run audit:deps",
    "quality-checks:ci": "pnpm run quality-checks",
    "quality": "pnpm run quality-checks",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply connections_helper_db --local",
    "db:migrate:remote": "wrangler d1 migrations apply connections_helper_db --remote",
    "prepare": "git config core.hooksPath .githooks 2>/dev/null || true"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "@cloudflare/vite-plugin": "^1.26.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@sentry/react": "^10.49.0",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/router-plugin": "^1.132.0",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^0.511.0",
    "posthog-js": "^1.369.3",
    "react": "^19.2.0",
    "react-day-picker": "^9.13.0",
    "react-dom": "^19.2.0",
    "tailwind-merge": "^3.3.0",
    "tailwindcss": "^4.1.18",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241218.0",
    "@playwright/test": "^1.52.0",
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/devtools-vite": "latest",
    "@tanstack/eslint-config": "latest",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@usebruno/cli": "^3.3.0",
    "@vitejs/plugin-react": "^6.0.1",
    "drizzle-kit": "^0.31.10",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "start-server-and-test": "^3.0.2",
    "typescript": "~5.9.3",
    "vite": "^8.0.0",
    "vitest": "^3.0.5",
    "wrangler": "^4.70.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  }
}
