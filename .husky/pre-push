#!/usr/bin/env sh

# Skip switch (real emergencies only).
if [ -n "$SKIP_QUALITY_CHECKS" ]; then
  echo "⏭️  SKIP_QUALITY_CHECKS set, skipping quality-checks hook"
  exit 0
fi

# Quality checks validate the *working tree*. If the push only includes refs
# OTHER than the current branch, the working tree does not represent the
# pushed code; defer to GitHub CI for those branches and skip locally.
# Pushing the current branch (alone or alongside others) still validates.
current_branch="$(git symbolic-ref --short HEAD 2>/dev/null || echo "")"
zero_sha="0000000000000000000000000000000000000000"

push_includes_current=0
push_includes_other_branch=0

while read -r local_ref local_sha remote_ref remote_sha; do
  # Skip ref deletions.
  [ "$local_sha" = "$zero_sha" ] && continue

  case "$remote_ref" in
    refs/heads/*)
      branch="${remote_ref#refs/heads/}"
      if [ "$branch" = "$current_branch" ]; then
        push_includes_current=1
      else
        push_includes_other_branch=1
      fi
      ;;
    *)
      # Tags or other refs: working-tree state does not apply.
      ;;
  esac
done

if [ "$push_includes_current" = "0" ] && [ "$push_includes_other_branch" = "1" ]; then
  echo "ℹ️  Pushing branch other than the current working tree ($current_branch)."
  echo "   Skipping local quality-checks (working tree does not match pushed ref)."
  echo "   GitHub CI runs the full quality gate on the pushed branch."
  exit 0
fi

echo "🔍 Running quality-checks before push (format + lint + build + test + audit)…"
pnpm quality-checks
